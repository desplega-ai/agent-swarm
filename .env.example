# Define your API key or leave empty for no auth
API_KEY=

# Base64-encoded 32-byte key for at-rest encryption of swarm_config secrets.
# If not set, server writes to <data-dir>/.encryption-key only when the DB does
# not yet contain encrypted secret rows (for example, a fresh DB or a first
# upgrade from plaintext-only secrets). Existing DBs with encrypted secrets fail
# closed instead of auto-generating a different key.
# BACK UP AND PRESERVE THE ACTUAL KEY MATERIAL — losing it means losing all
# encrypted secrets.
# Do not switch key sources unless the underlying base64 key value is identical.
# NOTE: If upgrading without this set, a one-time plaintext backup is created
# at <db-path>.backup.secrets-YYYY-MM-DD.env. Delete it after backing up your key.
# SECRETS_ENCRYPTION_KEY=
# SECRETS_ENCRYPTION_KEY_FILE=/run/secrets/encryption_key

# Server port (default: 3013, worktrees get a random port in 3100-3999)
PORT=3013

# ── Portless (local dev with friendly URLs) ─────────────────────────────
# Replaces port-based URLs with domain names. See CONTRIBUTING.md.
# Install: bun add -g portless
# HTTPS:   portless trust && portless proxy start --https
#
# When using portless, set these in your .env:
# MCP_BASE_URL=https://api.swarm.localhost:1355
# APP_URL=https://ui.swarm.localhost:1355
# ────────────────────────────────────────────────────────────────────────

# Swarm URL for service discovery (e.g., swarm.example.com)
# Services are accessible at https://{AGENT_ID}.{SWARM_URL}
SWARM_URL=localhost

# MCP Base URL — internal/worker-facing API base (workers, UI, setup command)
# Default: https://api.desplega.agent-swarm.dev
MCP_BASE_URL=

# Public, externally-reachable API origin for OAuth redirect URIs + webhook URLs.
# Defaults to MCP_BASE_URL when unset — only set in split deploys where MCP_BASE_URL
# is an internal/cluster address that external providers (Linear/Jira/GitHub) can't reach.
# PUBLIC_MCP_BASE_URL=

# Slack Bot Configuration (Socket Mode)
# Get these from https://api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-...      # Bot User OAuth Token
SLACK_APP_TOKEN=xapp-...      # App-Level Token (for Socket Mode)
SLACK_SIGNING_SECRET=...      # Signing Secret (optional for Socket Mode)
SLACK_DISABLE=true            # Set to "true" to disable Slack integration

# Additive Slack — buffer non-mention thread replies and batch into follow-up tasks
# ADDITIVE_SLACK=true                     # Enable thread message buffering (default: false)
# ADDITIVE_SLACK_BUFFER_MS=10000          # Debounce window in ms (default: 10000)

# Thread follow-up mention requirement — require @mention for thread follow-up routing
# SLACK_THREAD_FOLLOWUP_REQUIRE_MENTION=true  # Default: false (current behavior preserved)

# Slack User Filtering (optional - leave empty to allow all users)
# SLACK_ALLOWED_EMAIL_DOMAINS=desplega.ai,partner.com  # Comma-separated email domains
# SLACK_ALLOWED_USER_IDS=U12345678,U87654321           # Comma-separated Slack user IDs to always allow

# App URL for Slack message links (e.g., https://your-dashboard.com)
APP_URL=

# Environment mode - set to "development" to add (dev) prefix to agent names in Slack
ENV=

# GitHub App Integration (optional)
# GITHUB_DISABLE=true             # Set to skip GitHub integration
GITHUB_WEBHOOK_SECRET=            # Webhook secret from GitHub App settings
GITHUB_BOT_NAME=agent-swarm-bot   # Bot name for @mentions (default: agent-swarm-bot)
GITHUB_BOT_ALIASES=               # Comma-separated additional @mention aliases (e.g. heysidekick,sidekick)
# GITHUB_EVENT_LABELS=swarm-review  # Comma-separated labels that trigger agent action on PR/issue label events (default: swarm-review)
GITHUB_APP_ID=                    # GitHub App ID (from app settings)
GITHUB_APP_PRIVATE_KEY=           # Private key: raw PEM with \n escapes, OR base64-encoded

# Scheduler configuration
SCHEDULER_INTERVAL_MS=10000       # Polling interval for scheduled tasks (default: 10 seconds)

# AgentMail Integration (optional)
# AGENTMAIL_DISABLE=true                # Set to skip AgentMail integration
AGENTMAIL_WEBHOOK_SECRET=               # Svix signing secret for webhook verification

# Kapso / WhatsApp Integration (optional)
# Native inbound webhook handler + outbound MCP text tools
# KAPSO_API_KEY=                        # Kapso API key (X-API-Key header)
# KAPSO_PHONE_NUMBER_ID=                # WhatsApp Business phone-number ID the swarm sends from
# KAPSO_WEBHOOK_HMAC_SECRET=            # Shared secret for X-Webhook-Signature verification
# KAPSO_API_BASE_URL=https://api.kapso.ai  # Optional Kapso API base URL override

# ── Linear Integration ──
# Create an OAuth app at: https://linear.app/settings/api/applications
# 1. Set Actor to "Application"
# 2. Set Callback URL to your /api/trackers/linear/callback endpoint
# 3. Enable "Agent session events" in webhook settings
# 4. Set Webhook URL to your /api/trackers/linear/webhook endpoint
# 5. Copy Client ID, Client Secret, and Webhook Signing Secret below
# 6. Start server, then visit /api/trackers/linear/authorize to complete OAuth
#
# LINEAR_DISABLE=true                    # Set to disable Linear integration
# LINEAR_CLIENT_ID=                      # OAuth app client ID
# LINEAR_CLIENT_SECRET=                  # OAuth app client secret (shown once on creation)
# LINEAR_REDIRECT_URI=http://localhost:3013/api/trackers/linear/callback
# With portless: LINEAR_REDIRECT_URI=https://api.swarm.localhost:1355/api/trackers/linear/callback
# LINEAR_SIGNING_SECRET=                 # Webhook signing secret (from app settings)

# ── Jira Integration ──
# Create an OAuth 2.0 (3LO) integration at:
#   https://developer.atlassian.com/console/myapps/
# 1. Add scopes: read:jira-work, write:jira-work, manage:jira-webhook,
#    offline_access, read:me
# 2. Set Callback URL to your /api/trackers/jira/callback endpoint
# 3. Generate a webhook URL token: `openssl rand -hex 32` (set as JIRA_WEBHOOK_TOKEN)
#    Atlassian does NOT HMAC-sign OAuth 3LO dynamic webhooks — we authenticate
#    inbound deliveries by matching the URL-path token instead. Treat this token
#    like a Slack incoming-webhook URL: anyone who can read it can post events.
# 4. Copy Client ID, Client Secret below
# 5. Start server, then visit /api/trackers/jira/authorize to complete OAuth
#
# JIRA_DISABLE=true                      # Set to disable Jira integration
# JIRA_ENABLED=false                     # Alternate kill switch (default: enabled if JIRA_CLIENT_ID set)
# JIRA_CLIENT_ID=                        # OAuth app client ID
# JIRA_CLIENT_SECRET=                    # OAuth app client secret
# JIRA_REDIRECT_URI=http://localhost:3013/api/trackers/jira/callback
# With portless: JIRA_REDIRECT_URI=https://api.swarm.localhost:1355/api/trackers/jira/callback
# JIRA_WEBHOOK_TOKEN=                    # `openssl rand -hex 32` — embedded in webhook URL path

# Business-Use instrumentation (optional)
# Run `uvx business-use-core@latest init` to generate an API key
# BUSINESS_USE_API_KEY=             # API key from `business-use init`
# BUSINESS_USE_URL=http://localhost:13370  # BU backend URL (default if omitted)

# Anonymized telemetry (optional)
# Enabled by default. Set to "false" to disable.
# ANONYMIZED_TELEMETRY=false

# Portable model-tier overrides (worker-side; optional)
# Applies when tasks, schedules, or workflows set modelTier instead of a concrete model.
# MODEL_TIER_MAP={"smol":"gpt-5.4-mini","regular":"gpt-5.4","smart":"gpt-5.5","ultra":"gpt-5.5"}
# MODEL_TIER_SMART=gpt-5.5              # Per-tier override wins over MODEL_TIER_MAP

# Memory system - OpenAI embeddings (API server only, NOT needed in workers)
# Optional: system works without it but memory search degrades to recency-based
OPENAI_API_KEY=

# Memory rater (Stop hook session summarizer + LLM rater piggyback)
# Requires OPENROUTER_API_KEY — when unset, session-summary indexing and the
# llm rater are no-ops (self-hosters / OSS users skip both rather than use the
# previous broken claude CLI path). Override the model with any OpenRouter slug.
# OPENROUTER_API_KEY=
# MEMORY_RATER_LLM_MODEL=google/gemini-3-flash-preview  # default

# pi-mono + Amazon Bedrock (optional)
# BEDROCK_AUTH_MODE=sdk                # Optional explicit mode; when unset, MODEL_OVERRIDE=amazon-bedrock/* also activates SDK mode
# AWS_REGION=us-east-1                 # Required for Bedrock SDK mode; used for credential probing and live model enumeration

# Context-mode MCP wiring for local harnesses (Claude Code, Codex, opencode)
# Enabled by default. Set to true to hide/skip the ctx_* tools for a worker.
# CONTEXT_MODE_DISABLED=true

# ── Cloud personalization & adaptive home (optional) ──
# Brand the swarm and gate cloud-only UX. All identity envs are read on every
# GET /status call — see docs-site .../guides/personalization.mdx.
# SWARM_CLOUD=false                       # true = cloud mode (Docs/Support/Billing menu, hides self-host footer)
# SWARM_ORG_NAME=Swarm                    # Sidebar header name
# SWARM_ORG_LOGO_URL=                     # Sidebar logo URL (HTTPS); falls back to bundled /logo.png
# SWARM_BRAND_COLOR=                      # Tints the org name (any CSS color, e.g. #a855f7)
# SWARM_MARKETING_URL=                    # Self-host marketing footer link target (suppressed when SWARM_CLOUD=true)
# SWARM_HIDE_CLOUD_PROMO=false            # Force-hide the marketing footer regardless of SWARM_CLOUD
# SWARM_VERIFY_TTL_MS=3600000             # How long a successful "Test connection" keeps harness milestone verified (default 1h, in-memory)
