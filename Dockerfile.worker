# Agent Swarm Worker Dockerfile
# Runs Claude in headless loop mode as a worker agent
# Multi-stage build: compiles to standalone binary with full dev environment

ARG PREK_VERSION=0.4.5

# Official prek docs recommend copying the pinned binary from its distroless
# image into Debian-based images.
FROM ghcr.io/j178/prek:v${PREK_VERSION} AS prek

# Stage 1: Build the binary
FROM oven/bun:1.3.11 AS builder
WORKDIR /build
# Root package.json declares Bun workspaces (ui/templates-ui/evals); their manifests +
# bunfig.toml (pins linker="hoisted"; the workspace default "isolated" would hide the
# root's phantom transitive deps and break the compile) must be present for the frozen
# install to resolve the workspace graph. Member deps land in the builder only; the final
# image copies just the compiled binary, so image size is unaffected.
COPY package.json bun.lock* bunfig.toml ./
COPY ui/package.json ./ui/package.json
COPY templates-ui/package.json ./templates-ui/package.json
COPY evals/package.json ./evals/package.json
RUN bun install --frozen-lockfile
COPY src/ ./src/
COPY templates/ ./templates/
COPY tsconfig.json ./
RUN bun build ./src/cli.tsx --compile --compile-exec-argv='--expose-gc' --outfile ./agent-swarm

# Stage 2: Full development environment
FROM ubuntu:24.04

# Prevent interactive prompts during package installation
ENV DEBIAN_FRONTEND=noninteractive

# Use pipefail so pipe failures are caught
SHELL ["/bin/bash", "-o", "pipefail", "-c"]

# Install all system packages in a single layer
# Step 1: bootstrap curl/gnupg so we can add external apt repos
# Step 2: add NodeSource + GitHub CLI repos, then install everything
# NOTE: intentionally NOT using --no-install-recommends here — this is a full
# dev environment where agents build arbitrary projects; recommended packages
# (setuptools, wheel, less, dev headers, etc.) prevent subtle breakage.
RUN apt-get update && apt-get install -y curl ca-certificates gnupg \
    && curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
       | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg \
    && chmod go+r /usr/share/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
       | tee /etc/apt/sources.list.d/github-cli.list > /dev/null \
    && apt-get update && apt-get install -y \
    wget lsb-release \
    git git-lfs \
    vim nano \
    build-essential make cmake gcc g++ \
    python3 python3-pip python3-venv \
    jq tree htop unzip zip tar gzip sqlite3 fuse3 libfuse2 gosu tini \
    openssh-client \
    postgresql-client \
    postgresql-16 \
    postgresql-contrib-16 \
    nodejs \
    gh \
    tmux \
    && rm -rf /var/lib/apt/lists/*

# Redis server for tasks that need a local queue/cache backend (always bundled).
# Runtime start is controlled by SWARM_DEP_REDIS_ENABLED (default: false).
RUN apt-get update \
    && apt-get install -y --no-install-recommends redis-server redis-tools \
    && rm -rf /var/lib/apt/lists/*

# Install GitLab CLI (glab) for GitLab integration
ARG GLAB_VERSION=1.89.0
ARG TARGETARCH
RUN curl -fsSL "https://gitlab.com/api/v4/projects/gitlab-org%2Fcli/packages/generic/glab/${GLAB_VERSION}/glab_${GLAB_VERSION}_linux_${TARGETARCH}.deb" -o /tmp/glab.deb \
    && dpkg -i /tmp/glab.deb \
    && rm /tmp/glab.deb

# Install Bun (for running JS/TS projects)
RUN curl -fsSL https://bun.sh/install | bash
ENV BUN_INSTALL="/root/.bun"
ENV PATH="$BUN_INSTALL/bin:$PATH"

# Create non-root user for runtime execution.
# NOTE: Container entrypoint runs as root for FUSE mount compatibility.
# Final exec drops to worker via gosu (Claude rejects --dangerously-skip-permissions as root).
# Worker user retained for file ownership and Claude process execution.
RUN useradd -m -s /bin/bash worker

USER worker
WORKDIR /home/worker
ENV HOME=/home/worker
ENV BUN_INSTALL="/home/worker/.bun"

# Redirect corepack home to user-writable directory (default /usr/lib/node_modules/
# requires root and causes "operation rejected by your operating system" errors)
ENV COREPACK_HOME=/home/worker/.corepack
RUN mkdir -p /home/worker/.corepack

# Pre-create XDG dirs as worker so that later root-level steps writing into
# /home/worker (HOME is still set to /home/worker under USER root) don't leave
# /home/worker/.local root-owned and break worker-side mkdir into .local/share.
RUN mkdir -p /home/worker/.local/bin /home/worker/.local/share /home/worker/.local/state

# Install Bun for worker user (need to set HOME explicitly in RUN)
RUN HOME=/home/worker BUN_INSTALL=/home/worker/.bun curl -fsSL https://bun.sh/install | bash
ENV PATH="/home/worker/.bun/bin:$PATH"

# Install Claude CLI (pinned version — bump ARG to update)
ARG CLAUDE_CODE_VERSION=2.1.197
USER root
RUN HOME=/root NPM_CONFIG_CACHE=/tmp/npm-cache \
    npm install -g @anthropic-ai/claude-code@${CLAUDE_CODE_VERSION} \
    && rm -rf /tmp/npm-cache /root/.npm
USER worker
# Verify claude binary is findable after install
RUN which claude && claude --version
ENV DISABLE_AUTOUPDATER=1
ENV PATH="/home/worker/.local/bin:$PATH"

# Install pi-mono CLI (alternative harness, selected via HARNESS_PROVIDER=pi)
# PI_PACKAGE_DIR tells pi-mono where to find its package.json at runtime
# (needed because bun --compile makes process.execPath resolve to the binary location)
ARG PI_CODING_AGENT_VERSION=0.80.3
USER root
RUN HOME=/root NPM_CONFIG_CACHE=/tmp/npm-cache \
    npm install -g @earendil-works/pi-coding-agent@${PI_CODING_AGENT_VERSION} \
    && rm -rf /tmp/npm-cache /root/.npm
USER worker
RUN mkdir -p /home/worker/.pi/agent
ENV PI_PACKAGE_DIR=/usr/lib/node_modules/@earendil-works/pi-coding-agent

# Install Codex CLI (alternative harness, selected via HARNESS_PROVIDER=codex)
# Pinned version must match @openai/codex-sdk in package.json — enforced by
# scripts/check-codex-default-model.sh and the CI merge gate.
ARG CODEX_VERSION=0.142.5
USER root
RUN HOME=/root NPM_CONFIG_CACHE=/tmp/npm-cache \
    npm install -g @openai/codex@${CODEX_VERSION} \
    && rm -rf /tmp/npm-cache /root/.npm
USER worker
RUN which codex && codex --version

# The @openai/codex-sdk bundled inside the compiled agent-swarm binary cannot
# resolve `require.resolve("@openai/codex")` at runtime because the globally-
# installed package is not part of the Bun bundle. Point the SDK at the global
# Codex CLI wrapper via CODEX_PATH_OVERRIDE so `src/providers/codex-adapter.ts`
# forwards it to `new Codex({ codexPathOverride })`. The wrapper is a node
# shebang script that resolves the platform-specific native binary itself.
ENV CODEX_PATH_OVERRIDE=/usr/bin/codex

# Baseline ~/.codex/config.toml for the worker user. The `model` key must stay
# in sync with CODEX_DEFAULT_MODEL in src/providers/codex-models.ts (enforced by
# scripts/check-codex-default-model.sh).
RUN mkdir -p /home/worker/.codex && \
    printf '%s\n' \
      'model = "gpt-5.4"' \
      'approval_policy = "never"' \
      'sandbox_mode = "danger-full-access"' \
      'skip_git_repo_check = true' \
      'show_raw_agent_reasoning = false' \
      '' \
      '[features]' \
      'hooks = true' \
      'plugin_hooks = true' \
      > /home/worker/.codex/config.toml && \
    chown -R worker:worker /home/worker/.codex

# Install the context-mode Codex plugin (provides the ctx_* hooks for the Codex
# harness). The [features] block above enables hooks + plugin-provided hooks.
# Guarded with || true so a marketplace/registry hiccup can't fail the build.
RUN codex plugin marketplace add mksglu/context-mode || true \
    && codex plugin install context-mode@context-mode || true

# Install opencode CLI + SDK (alternative harness, selected via HARNESS_PROVIDER=opencode)
# CLI version must match SDK version — the SDK spawns `opencode serve` and parses
# its stdout for the listening URL (see node_modules/@opencode-ai/sdk/dist/server.js).
# The installer drops the binary at ~/.opencode/bin/opencode and only modifies
# ~/.bashrc — non-interactive shells (entrypoint, gosu drops) miss that PATH
# update, so we extend ENV PATH explicitly.
ARG OPENCODE_VERSION=1.17.12
RUN curl -fsSL https://opencode.ai/install | VERSION=${OPENCODE_VERSION} bash
ENV PATH="/home/worker/.opencode/bin:$PATH"
ARG OPENCODE_SDK_VERSION=1.17.12
USER root
RUN HOME=/root NPM_CONFIG_CACHE=/tmp/npm-cache \
    npm install -g @opencode-ai/sdk@${OPENCODE_SDK_VERSION} \
    && rm -rf /tmp/npm-cache /root/.npm
USER worker

# Install context-mode CLI globally (context-window compression tools for all
# harnesses). The global install puts `context-mode` on PATH (for Claude/Codex
# stdio MCP) AND makes the package importable (for the OpenCode in-process
# plugin). The Claude/Codex plugin installs provide the hooks; this provides
# the CLI binary + package importability. Disable per-worker via
# CONTEXT_MODE_DISABLED=true (read by the adapters at runtime).
ARG CONTEXT_MODE_VERSION=1.0.151
USER root
RUN HOME=/root NPM_CONFIG_CACHE=/tmp/npm-cache \
    npm install -g context-mode@${CONTEXT_MODE_VERSION} \
    && rm -rf /tmp/npm-cache /root/.npm
USER worker

# Install prek for opt-in worker repo hook setup.
COPY --from=prek /prek /usr/local/bin/prek

# Install Claude marketplace plugins (build-time cache)
RUN mkdir -p /home/worker/.claude \
    # Main desplega toolbox plugin
    && claude plugin marketplace add desplega-ai/ai-toolbox@cc-desplega-2.0.0 || true \
    && claude plugin install desplega@desplega-ai-toolbox --scope user || true \
    # Worktree management
    && claude plugin install wts@desplega-ai-toolbox --scope user || true \
    # desplega.ai qa-use CLI
    && claude plugin marketplace add desplega-ai/qa-use || true \
    && claude plugin install qa-use@desplega.ai --scope user || true \
    # context-mode to improve context-window usage. NOTE: this plugin (which
    # provides the ctx_* HOOKS) tracks the marketplace HEAD and is NOT version-
    # pinned. A build-time `git checkout v${CONTEXT_MODE_VERSION}` in the
    # marketplace clone does not work (git rejects it with "dubious ownership"
    # and the clone is shallow without tags), so we don't attempt it. The ctx_*
    # TOOLS are served by the globally-installed CLI (npm i -g
    # context-mode@${CONTEXT_MODE_VERSION} above), which IS pinned; only the
    # hook bundle floats — acceptable since the hooks are backward-compatible.
    && claude plugin marketplace add mksglu/claude-context-mode || true \
    && claude plugin install context-mode@context-mode --scope user || true \
    # agent-fs goodies
    && claude plugin marketplace add desplega-ai/agent-fs || true \
    && claude plugin install agent-fs@agent-fs --scope user || true

# Configure wts for agent mode (no tmux, no auto-Claude)
RUN mkdir -p /home/worker/.wts \
    && echo '{"defaults":{"autoTmux":false,"autoClaude":false}}' > /home/worker/.wts/config.json

# Setup .claude directory and settings
RUN mkdir -p /home/worker/.claude/commands /home/worker/.claude/agents \
    && echo '{"hasCompletedOnboarding":true,"bypassPermissionsModeAccepted":true}' > /home/worker/.claude.json \
    && echo '{ \
  "permissions": { "allow": ["mcp__agent-swarm__*", "mcp__context-mode__*"] }, \
  "enableAllProjectMcpServers": true, \
  "enabledMcpjsonServers": ["agent-swarm", "context-mode"], \
  "hooks": { \
    "SessionStart": [{"matcher": "*", "hooks": [{"type": "command", "command": "/usr/local/bin/agent-swarm hook"}]}], \
    "UserPromptSubmit": [{"matcher": "*", "hooks": [{"type": "command", "command": "/usr/local/bin/agent-swarm hook"}]}], \
    "PreToolUse": [{"matcher": "*", "hooks": [{"type": "command", "command": "/usr/local/bin/agent-swarm hook"}]}], \
    "PostToolUse": [{"matcher": "*", "hooks": [{"type": "command", "command": "/usr/local/bin/agent-swarm hook"}]}], \
    "PreCompact": [{"matcher": "*", "hooks": [{"type": "command", "command": "/usr/local/bin/agent-swarm hook"}]}], \
    "Stop": [{"matcher": "*", "hooks": [{"type": "command", "command": "/usr/local/bin/agent-swarm hook"}]}] \
  } \
}' > /home/worker/.claude/settings.json

# Install global npm tools (pinned versions for cache stability).
#
# We use a staging-dir `npm install` + symlink pattern instead of `npm install -g`
# so we can apply an `overrides` workaround for a broken upstream transitive:
#   @desplega.ai/agent-fs -> chonkie -> @huggingface/hub@2.11.1
#     -> @huggingface/xetchunk-wasm@0.0.4
# xetchunk-wasm@0.0.4 was published with `gearhash-jit: workspace:*` and
# `@huggingface/blake3-jit: workspace:*` — neither sibling is on npm, so a
# global install hits EUNSUPPORTEDPROTOCOL in uncached environments. Pinning
# `@huggingface/hub` to 2.11.0 (the last version before xetchunk-wasm became
# a dep) sidesteps it. Drop this workaround once HF republishes a clean
# xetchunk-wasm and chonkie / agent-fs pull it in.
USER root
RUN mkdir -p /opt/global-deps && cat > /opt/global-deps/package.json <<'EOF'
{
  "name": "global-deps",
  "private": true,
  "dependencies": {
    "pm2": "6.0.14",
    "@sentry/cli": "3.3.4",
    "@desplega.ai/wts": "0.2.3",
    "@desplega.ai/localtunnel": "2.2.0",
    "@desplega.ai/qa-use": "2.19.0",
    "@desplega.ai/claude-bridge": "0.2.2",
    "@desplega.ai/agent-fs": "0.9.0"
  },
  "overrides": {
    "@huggingface/hub": "2.11.0",
    "chromadb": "npm:empty-npm-package@1.0.0",
    "chromadb-default-embed": "npm:empty-npm-package@1.0.0",
    "@xenova/transformers": "npm:empty-npm-package@1.0.0",
    "tree-sitter-wasms": "npm:empty-npm-package@1.0.0",
    "web-tree-sitter": "npm:empty-npm-package@1.0.0",
    "cohere-ai": "npm:empty-npm-package@1.0.0",
    "voyageai": "npm:empty-npm-package@1.0.0",
    "ollama": "npm:empty-npm-package@1.0.0"
  }
}
EOF

# Playwright browsers live in a system path so they're shared across users at
# runtime AND so the install doesn't pollute /home/worker (which would force a
# multi-GB chown layer). The ENV is also read by Playwright at runtime.
ENV PLAYWRIGHT_BROWSERS_PATH=/opt/playwright

# Install global deps + Playwright chromium. CRITICAL: `ENV HOME=/home/worker`
# (line 70) is still active under `USER root`, so without the inline override
# below npm/Playwright would dump ~/.npm (~830 MB) and ~/.cache/ms-playwright
# (~930 MB) into /home/worker as root-owned files — which previously required
# a `chown -R worker:worker /home/worker` step that re-wrote the entire HOME
# as a 5+ GB duplicate layer. By keeping HOME=/root and the npm cache in
# /tmp, then cleaning them in the same RUN, the chown becomes unnecessary.
RUN HOME=/root NPM_CONFIG_CACHE=/tmp/npm-cache \
    sh -c 'mkdir -p /opt/playwright \
      && cd /opt/global-deps && npm install --no-audit --no-fund \
      && for bin in /opt/global-deps/node_modules/.bin/*; do \
           ln -sf "$bin" "/usr/local/bin/$(basename "$bin")"; \
         done \
      && qa-use install-deps' \
    && rm -rf /tmp/npm-cache /root/.npm /root/.cache \
    && chmod -R a+rX /opt/playwright

# Install archil CLI for FUSE/R2-backed disk mounts
RUN curl https://s3.amazonaws.com/archil-client/install | sh

# Copy binary from builder (changes on every code change — keep late)
COPY --from=builder /build/agent-swarm /usr/local/bin/agent-swarm
RUN chmod +x /usr/local/bin/agent-swarm

# Optional helper to start a local PostgreSQL 16 cluster (not invoked automatically)
COPY scripts/init-local-postgres.sh /usr/local/bin/init-local-postgres.sh
RUN chmod +x /usr/local/bin/init-local-postgres.sh

# Optional helper to start local Redis (not invoked automatically)
COPY scripts/init-local-redis.sh /usr/local/bin/init-local-redis.sh
RUN chmod +x /usr/local/bin/init-local-redis.sh

# Best-effort repo hook installer used after opt-in worker repo clones.
COPY scripts/install-repo-hooks.sh /usr/local/bin/install-repo-hooks.sh
RUN chmod +x /usr/local/bin/install-repo-hooks.sh

# Copy commands (changes on code change — keep late)
COPY --chown=worker:worker plugin/commands/* /home/worker/.claude/commands/
COPY --chown=worker:worker plugin/agents/* /home/worker/.claude/agents/
COPY --chown=worker:worker plugin/skills/ /home/worker/.claude/skills/

# Copy pi-mono skills (used when HARNESS_PROVIDER=pi)
COPY --chown=worker:worker plugin/pi-skills/ /home/worker/.pi/agent/skills/

# Copy codex skills (used when HARNESS_PROVIDER=codex)
# Structure: plugin/commands/<name>.md -> ~/.codex/skills/<name>/SKILL.md
COPY --chown=worker:worker plugin/commands/ /tmp/codex-skills-src/
RUN mkdir -p /home/worker/.codex/skills && \
    for f in /tmp/codex-skills-src/*.md; do \
      [ -e "$f" ] || continue; \
      name=$(basename "$f" .md); \
      mkdir -p "/home/worker/.codex/skills/$name"; \
      cp "$f" "/home/worker/.codex/skills/$name/SKILL.md"; \
    done && \
    rm -rf /tmp/codex-skills-src && \
    chown -R worker:worker /home/worker/.codex/skills

# Mirror Claude-installed skills into every local harness skill tree. This
# includes marketplace/plugin skills installed under ~/.claude/skills during the
# build, not just the repository's plugin/commands conversion above.
RUN mkdir -p /home/worker/.pi/agent/skills /home/worker/.codex/skills /home/worker/.opencode/skills /home/worker/.agents/skills && \
    cp -a /home/worker/.claude/skills/. /home/worker/.pi/agent/skills/ || true && \
    cp -a /home/worker/.claude/skills/. /home/worker/.codex/skills/ || true && \
    cp -a /home/worker/.claude/skills/. /home/worker/.opencode/skills/ || true && \
    cp -a /home/worker/.claude/skills/. /home/worker/.agents/skills/ || true && \
    chown -R worker:worker /home/worker/.pi /home/worker/.codex /home/worker/.opencode /home/worker/.agents

# Copy opencode plugin (used when HARNESS_PROVIDER=opencode).
# OPENCODE_SWARM_PLUGIN_PATH tells OpencodeAdapter exactly where to find the
# plugin — the bundled binary's `import.meta.dir` is /usr/local/bin which
# doesn't help, and relying on opencode's auto-discovery is implicit (it
# silently breaks if discovery rules change or OPENCODE_CONFIG suppresses it).
#
# Phase 2 (session-summarization fix): the plugin entrypoint imports adjacent
# vendored helpers (`./opencode-auth`, `./summarize`). opencode's plugin
# loader runs the TS files inside its own bundled Bun runtime, which only
# exposes `@opencode-ai/{plugin,sdk}` — so the helpers are vendored, NOT
# imported from `@desplega.ai/agent-swarm`. COPY them next to the entrypoint
# so the relative imports resolve. Tests live in a sibling `tests/`
# subdirectory and are intentionally NOT copied (opencode auto-discovers
# `.ts` files in this directory and would try to load them as plugins).
RUN mkdir -p /home/worker/.config/opencode/plugins/lib && \
    chown -R worker:worker /home/worker/.config
COPY --chown=worker:worker plugin/opencode-plugins/agent-swarm.ts /home/worker/.config/opencode/plugins/agent-swarm.ts
COPY --chown=worker:worker plugin/opencode-plugins/lib/ /home/worker/.config/opencode/plugins/lib/
ENV OPENCODE_SWARM_PLUGIN_PATH=/home/worker/.config/opencode/plugins/agent-swarm.ts

# Create directories and copy entrypoint
RUN mkdir -p /workspace /logs && chown worker:worker /workspace /logs
COPY --chown=worker:worker docker-entrypoint.sh /docker-entrypoint.sh
RUN chmod +x /docker-entrypoint.sh

USER root
WORKDIR /workspace

# Create mount-point directories (must be empty for Archil FUSE mounts)
RUN mkdir -p /workspace/personal /workspace/shared

# NOTE: Do NOT use VOLUME for /workspace/shared or /workspace/personal.
# Fly.io's init sets up volume mount points that prevent FUSE from mounting
# on top of them (EINVAL). Archil FUSE mounts replace Docker volumes here.
VOLUME ["/logs"]

# Expose service port for PM2 processes
EXPOSE 3000

# Environment
ENV AGENT_ROLE=worker
ENV HARNESS_PROVIDER=claude
ENV WORKER_YOLO=false
ENV MCP_BASE_URL=http://host.docker.internal:3013
ENV WORKER_LOG_DIR=/logs
ENV LEAD_LOG_DIR=/logs
ENV WORKER_SYSTEM_PROMPT=""
ENV WORKER_SYSTEM_PROMPT_FILE=""
ENV LEAD_SYSTEM_PROMPT=""
ENV LEAD_SYSTEM_PROMPT_FILE=""
ENV STARTUP_SCRIPT_STRICT=true
ENV TEMPLATE_REGISTRY_URL=https://templates.agent-swarm.dev
ENV PM2_HOME=/workspace/.pm2
ENV PATH="/home/worker/.local/bin:/home/worker/.bun/bin:$PATH"

ENTRYPOINT ["/docker-entrypoint.sh"]
