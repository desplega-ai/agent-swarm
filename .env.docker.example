# Docker Worker / Lead Agent Environment Variables
# Copy this file to .env.docker and fill in your values
# Full reference: docs/ENVS.md

# ---- Required ----
# Run `claude setup-token` to get your OAuth token
CLAUDE_CODE_OAUTH_TOKEN=your-oauth-token-here
API_KEY=your-api-key-here
# Required for Codex workers (`docker compose --profile codex up -d`)
OPENAI_API_KEY=
# Optional compatibility alias (entrypoint maps CODEX_API_KEY -> OPENAI_API_KEY)
CODEX_API_KEY=

# ---- Agent Identity ----
# Keep AGENT_ID stable across restarts for task resume and identity persistence
AGENT_ID=
AGENT_NAME=
AGENT_ROLE=worker                       # "worker" or "lead"

# ---- Codex Worker Identities (stable UUIDs recommended) ----
CODEX_AGENT_ID_PLANNER_1=
CODEX_AGENT_ID_BUILDER_LARGE_1=
CODEX_AGENT_ID_BUILDER_LARGE_2=
CODEX_AGENT_ID_BUILDER_TIGHT_1=
CODEX_AGENT_ID_REVIEW_BROAD_1=
CODEX_AGENT_ID_REVIEW_PERF_1=

# ---- Networking ----
MCP_BASE_URL=http://host.docker.internal:3013
SWARM_URL=swarm.example.com             # Base domain for service discovery
SERVICE_PORT=3000                        # Host port for exposed services

# ---- Behavior ----
YOLO=false                               # Keep spawning sessions even if one fails
# MAX_CONCURRENT_TASKS=1                 # Parallel tasks (default: 1 for worker, 2 for lead)
# SHUTDOWN_TIMEOUT=30000                 # Grace period (ms) before pausing tasks on shutdown

# ---- Codex Role/Model/Sandbox Tuning ----
CODEX_LOOP_SLEEP_SECONDS=8
CODEX_APPROVAL_POLICY=never

# Planner
CODEX_MODEL_PLANNER=gpt-5.2
CODEX_MODEL_REASONING_EFFORT_PLANNER=xhigh
CODEX_SANDBOX_PLANNER=read-only

# Builder (large)
CODEX_MODEL_BUILDER_LARGE=gpt-5.3-codex
CODEX_MODEL_REASONING_EFFORT_BUILDER_LARGE=xhigh
CODEX_SANDBOX_BUILDER_LARGE=workspace-write

# Builder (tight)
CODEX_MODEL_BUILDER_TIGHT=gpt-5.3-codex
CODEX_MODEL_REASONING_EFFORT_BUILDER_TIGHT=high
CODEX_SANDBOX_BUILDER_TIGHT=workspace-write

# Reviewer (broad)
CODEX_MODEL_REVIEW_BROAD=gpt-5.2
CODEX_MODEL_REASONING_EFFORT_REVIEW_BROAD=xhigh
CODEX_SANDBOX_REVIEW_BROAD=read-only

# Reviewer (perf)
CODEX_MODEL_REVIEW_PERF=gpt-5.3-codex
CODEX_MODEL_REASONING_EFFORT_REVIEW_PERF=xhigh
CODEX_SANDBOX_REVIEW_PERF=read-only

# ---- Logging ----
# SESSION_ID=                            # Reuse to continue logging to the same folder
# LOG_DIR=/logs                          # Base directory for session logs

# ---- System Prompt (optional) ----
SYSTEM_PROMPT=
SYSTEM_PROMPT_FILE=

# ---- Startup ----
STARTUP_SCRIPT_STRICT=true               # Exit if startup script fails

# ---- GitHub (for git operations) ----
GITHUB_TOKEN=                            # Personal access token for gh CLI and git push
GITHUB_EMAIL=worker-agent@desplega.ai    # Git commit email
GITHUB_NAME=Worker Agent                 # Git commit name

# ---- Sentry (optional) ----
# Create an Organization Auth Token at https://sentry.io/settings/{org}/auth-tokens/
# Required scopes: event:read, project:read, org:read
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
